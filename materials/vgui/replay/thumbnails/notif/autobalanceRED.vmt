"UnlitGeneric"
{
	"$translucent" 1
	"$vertexcolor" 1
	"$no_fullbright" 1
	"$ignorez" 1
	"%keywords" "tf"
	"$basetexture" "vgui/replay/thumbnails/notif/autobalanceRED"
	"Proxies" 
	{ 
		"AnimatedTexture" 
		{ 
			"animatedTextureVar" "$basetexture" 
			"animatedTextureFrameNumVar" "$frame" 
			"animatedTextureFrameRate" "2" 
		}
	}

}
