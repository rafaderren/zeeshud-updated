"UnlitGeneric"
{
	"<dx90"
	{
		$outlinecolor "[0.9 0.9 0.8]"
	}

	"$translucent" 1
	"$baseTexture" "hud\gradient_black_solid"
	"$detail" "hud\objectives_flagpanel_mask_text"
	$detailscale 1
	$detailblendmode 8
	$distancealphafromdetail 1

	// and a drop shadow
	$glow 1
	$glowcolor "[0 0 0]"
	$glowalpha 0.45
	$glowstart 0.1
	$glowend 0.5
	$glowx -0.001
	$glowy -0.001


//	"$vertexcolor" 1
	$distancealpha 1
	"$no_fullbright" 1
	"$ignorez" 1
	"%keywords" "tf"
}

